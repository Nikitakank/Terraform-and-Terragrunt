    border-bottom:1px solid var(--border);
    padding:14px 0;
    font-family:var(--mono);
    font-size:12.5px;
    color:var(--muted);
  }

  .topbar .eyebrow{
    color:var(--purple);
  }

  /* ===== HERO ===== */
  .hero{
    padding:48px 0 32px;
    border-bottom:1px solid var(--border);
  }

  .hero .kicker{
    font-family:var(--mono);
    font-size:12px;
    color:var(--muted);
    text-transform:lowercase;
    margin-bottom:14px;
    letter-spacing:0.3px;
  }

  .hero h1{
    font-size:34px;
    font-weight:800;
    letter-spacing:-0.5px;
    margin-bottom:14px;
    color:var(--text);
  }

  .hero h1 .accent{
    color:var(--purple);
  }

  .hero p{
    color:var(--muted);
    font-size:15.5px;
    max-width:620px;
    margin-bottom:20px;
  }

  .hero .terminal-tag{
    font-family:var(--mono);
    font-size:12.5px;
    color:var(--green);
    background:var(--panel);
    border:1px solid var(--border);
    border-radius:6px;
    padding:8px 12px;
    display:inline-block;
  }

  /* ===== TOC ===== */
